)\{<br>    const meta=user.user_metadata;<br>    if(!profile.nome&&meta.nome)\{profile.nome=meta.nome;sb.from('profiles').update(\{nome:meta.nome\}).eq('user_id',user.id)\}<br>    if(!profile.cognome&&meta.cognome)\{profile.cognome=meta.cognome;sb.from('profiles').update(\{cognome:meta.cognome\}).eq('user_id',user.id)\}<br>  \}<br>  const\{data:v\}=await sb.from('kata_videos').select('*').eq('user_id',user.id);<br>  kataVids=\{\};(v||[]).forEach(x=>\{if(!kataVids[x.kata_num])kataVids[x.kata_num]=[];kataVids[x.kata_num].push(x)\});<br>  const\{data:o\}=await sb.from('logbook_outings').select('*,logbook_routes(*,logbook_attempts(*))').eq('user_id',user.id).order('date',\{ascending:false\});<br>  logbook=(o||[]).map(x=>(\{id:x.id,date:x.date,falesia:x.falesia,vie:(x.logbook_routes||[]).map(r=>(\{id:r.id,nome:r.nome,grado:r.grado,tags:r.tags||[],tentativi:(r.logbook_attempts||[]).map(a=>(\{n:a.attempt_num,desc:a.description\}))\}))\}));<br>  let coins=0;Object.values(kataVids).forEach(vs=>vs.forEach(x=>\{if(x.status==='certified'&&x.is_public)coins+=5\}));<br>  profile.coins=coins;<br>  // Load community<br>  const\{data:members\}=await sb.from('profiles').select('*').neq('user_id',user.id);<br>  communityMembers=(members||[]).map(m=>(\{nome:m.nome,cognome:m.cognome,step:m.step,struttura:m.struttura,user_id:m.user_id\}));<br>\}<br><br>/* \u9552 \u9552 \u9552  ROLE HELPERS (Fase A) \u9552 \u9552 \u9552  */<br>function isStaff()\{return !!profile && (profile.role==='admin'||profile.role==='segreteria'||profile.role==='istruttore')\}<br>function isAdmin()\{return !!profile && profile.role==='admin'\}<br>function isSegreteria()\{return !!profile && (profile.role==='admin'||profile.role==='segreteria')\}<br><br>function applyRoleVisibility()\{<br>  const btn=document.getElementById('nav-segreteria');<br>  if(btn)btn.style.display=isStaff()?'':'none';<br>  const badge=document.getElementById('seg-role-badge');<br>  if(badge)badge.textContent=profile&&profile.role?profile.role:'';<br>  console.log('[KataClimb] role:',profile&&profile.role,'\'b7 isStaff:',isStaff(),'\'b7 isAdmin:',isAdmin());<br>  if(isStaff())loadCrmLeads();<br>\}<br><br>/* \u9552 \u9552 \u9552  CRM LEADS (Fase A \'b7 Step 2 + 3) \u9552 \u9552 \u9552  */<br>const FUNNEL_LABEL=\{nuovo:'Nuovo',contattato:'Contattato',prima_lezione_fissata:'1\'aa lezione fissata',prima_lezione_fatta:'1\'aa lezione fatta',iscritto:'Iscritto',perso:'Perso'\};<br>const FUNNEL_COLOR=\{nuovo:'#9CA3AF',contattato:'#EAB308',prima_lezione_fissata:'#EA580C',prima_lezione_fatta:'#16A34A',iscritto:'#2563EB',perso:'#9333EA'\};<br>const STATO_LABEL=\{attivo:'Attivo',da_richiamare:'Da richiamare',dormiente:'Dormiente'\};<br>const FONTE_LABEL=\{instagram:'Instagram',passaparola:'Passaparola',form_kataclimb:'Form KataClimb',form_syncrolink:'Form Syncrolink',form_accademia:'Form Accademia',whatsapp:'WhatsApp',telefono:'Telefono',altro:'Altro'\};<br>const URG_FILTERS=[<br>  \{key:'tutti',label:'Tutti',color:null\},<br>  \{key:'adesso',label:'Adesso',color:'#c0392b'\},<br>  \{key:'oggi',label:'Oggi',color:'#EA580C'\},<br>  \{key:'entro3',label:'Entro 3 giorni',color:'#EAB308'\},<br>  \{key:'oltre',label:'Oltre',color:'#9CA3AF'\}<br>];<br>let crmLeadsData=[];<br>let crmUrgencyFilter='tutti';<br><br>function fmtDate(d)\{if(!d)return'\'97';const dt=new Date(d);return dt.toLocaleDateString('it-IT',\{day:'2-digit',month:'short'\})\}<br>function dayDelta(d)\{if(!d)return null;const dt=new Date(d);const t=new Date();dt.setHours(0,0,0,0);t.setHours(0,0,0,0);return Math.round((dt-t)/86400000)\}<br>function urgencyKey(delta)\{if(delta===null)return'oltre';if(delta<0)return'adesso';if(delta===0)return'oggi';if(delta<=3)return'entro3';return'oltre'\}<br><br>function renderUrgencyFilters()\{<br>  const box=document.getElementById('seg-urgency-filters');<br>  if(!box)return;<br>  const counts=\{tutti:crmLeadsData.length,adesso:0,oggi:0,entro3:0,oltre:0\};<br>  crmLeadsData.forEach(l=>\{counts[urgencyKey(dayDelta(l.prossima_azione_il))]++\});<br>  box.innerHTML=URG_FILTERS.map(f=>\{<br>    const active=crmUrgencyFilter===f.key;<br>    const dot=f.color?`<span style="width:8px;height:8px;border-radius:50%;background:$\{f.color\};display:inline-block"></span>`:'';<br>    const bg=active?'var(--text)':'rgba(0,0,0,.04)';<br>    const fg=active?'var(--bg)':'var(--text2)';<br>    return`<button onclick="setUrgencyFilter('$\{f.key\}')" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:6px 12px;border-radius:20px;border:none;cursor:pointer;background:$\{bg\};color:$\{fg\};font-family:inherit;text-transform:uppercase;letter-spacing:.5px;transition:all .15s">$\{dot\}$\{f.label\} <span style="opacity:.6;font-weight:600">$\{counts[f.key]\}</span></button>`;<br>  \}).join('');<br>\}<br><br>function setUrgencyFilter(k)\{crmUrgencyFilter=k;renderUrgencyFilters();renderCrmLeads()\}<br><br>async function loadCrmLeads()\{<br>  const list=document.getElementById('seg-leads-list');<br>  if(!list)return;<br>  list.innerHTML='<p style="font-size:12px;color:var(--text3);padding:20px 0">Carico lead\'85</p>';<br>  const\{data,error\}=await sb.from('crm_leads').select('*').order('prossima_azione_il',\{ascending:true,nullsFirst:false\});<br>  if(error)\{list.innerHTML='<p style="font-size:12px;color:#c0392b;padding:20px 0">Errore: '+error.message+'</p>';console.error('[CRM]',error);return\}<br>  crmLeadsData=data||[];<br>  renderUrgencyFilters();<br>  renderCrmLeads();<br>\}<br><br>function renderCrmLeads()\{<br>  const list=document.getElementById('seg-leads-list');<br>  const cnt=document.getElementById('seg-leads-count');<br>  if(!list)return;<br>  const filtered=crmUrgencyFilter==='tutti'?crmLeadsData:crmLeadsData.filter(l=>urgencyKey(dayDelta(l.prossima_azione_il))===crmUrgencyFilter);<br>  if(cnt)cnt.textContent=filtered.length+(filtered.length===crmLeadsData.length?' lead':' di '+crmLeadsData.length+' lead');<br>  if(!filtered.length)\{list.innerHTML='<div class="card fu" style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Nessun lead in questa fascia.</div>';return\}<br>  list.innerHTML=filtered.map(l=>\{<br>    const delta=dayDelta(l.prossima_azione_il);<br>    let urgenza='';let urgColor='var(--text3)';<br>    if(delta!==null)\{<br>      if(delta<0)\{urgenza='Adesso \'b7 da '+Math.abs(delta)+'g';urgColor='#c0392b'\}<br>      else if(delta===0)\{urgenza='oggi';urgColor='#EA580C'\}<br>      else if(delta<=3)\{urgenza='tra '+delta+'g';urgColor='#EAB308'\}<br>      else\{urgenza='tra '+delta+'g';urgColor='var(--text3)'\}<br>    \}<br>    const fColor=FUNNEL_COLOR[l.funnel_stage]||'#9CA3AF';<br>    const fLabel=FUNNEL_LABEL[l.funnel_stage]||l.funnel_stage;<br>    const sLabel=STATO_LABEL[l.stato_gestione]||l.stato_gestione;<br>    const fonteLabel=FONTE_LABEL[l.fonte]||l.fonte;<br>    const nomeCompleto=(l.nome||'')+(l.cognome?' '+l.cognome:'');<br>    return`<div class="card fu" style="padding:16px 18px;margin-bottom:10px"><br>      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:8px"><br>        <div style="flex:1;min-width:0"><br>          <div style="font-family:var(--serif);font-size:16px;font-weight:500;color:var(--text);margin-bottom:2px">$\{nomeCompleto\}</div><br>          <div style="font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px">$\{fonteLabel\}$\{l.telefono?' \'b7 '+l.telefono:''\}</div><br>        </div><br>        <div style="text-align:right;font-size:11px"><br>          <div style="color:$\{urgColor\};font-weight:600;margin-bottom:2px">$\{urgenza||'\'97'\}</div><br>          <div style="color:var(--text3)">$\{fmtDate(l.prossima_azione_il)\}</div><br>        </div><br>      </div><br>      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px"><br>        <span style="display:inline-flex;align-items:center;gap:5px;font-size:11px;padding:3px 9px;border-radius:20px;background:rgba(0,0,0,.04);color:var(--text2)"><span style="width:7px;height:7px;border-radius:50%;background:$\{fColor\}"></span>$\{fLabel\}</span><br>        <span style="font-size:11px;padding:3px 9px;border-radius:20px;background:rgba(0,0,0,.04);color:var(--text2)">$\{sLabel\}</span><br>      </div><br>      $\{l.note?`<p style="font-size:12px;color:var(--text2);line-height:1.5;margin-top:10px;padding-top:10px;border-top:1px solid var(--border)">$\{l.note\}</p>`:''\}<br>    </div>`;<br>  \}).join('');<br>\}<br><br>/* \u9552 \u9552 \u9552  APP RENDERING \u9552 \u9552 \u9552  */<br><br>function renderApp()\{<br>  applyRoleVisibility();<br>  const si=STEPS[profile.step||0];<br>  document.getElementById('brand-dot').style.color=si.color;<br>  document.getElementById('coins-display').textContent='\'80'+(profile.coins||0);<br>  renderProg('my-prog-bar','my-prog-current',profile.step||0,profile.enrolled_next||false);<br>  // Avatar<br>  const av=document.getElementById('my-avatar');<br>  const pn=profile.nome||'';const pc=profile.cognome||'';<br>  const ini=(pn[0]||'?')+(pc[0]||'');<br>  av.innerHTML=profile.photo_url?`<img src="$\{profile.photo_url\}" alt="foto">`:ini;<br>  // Info<br>  document.getElementById('my-profile-info').innerHTML=`<h1>$\{pn\} <em>$\{pc\}</em></h1><br>    <div class="profile-level"><div class="dot" style="background:$\{si.color\}"></div><span>$\{si.label\} \'b7 $\{profile.struttura||'KataClimb'\}</span></div>`;<br>  renderTabs('my-course-tabs',myTabIdx,'my');<br>  renderPhase('my-phase-label',CT[myTabIdx]);<br>  renderKataGrid('my-kata-grid',kataVids,profile.step||0,false,myTabIdx);<br>  document.getElementById('my-logbook-list').innerHTML=renderLogbookHTML(logbook,false);<br>  renderCommunity();<br>\}<br><br>function myTab(i)\{myTabIdx=i;renderTabs('my-course-tabs',i,'my');renderPhase('my-phase-label',CT[i]);renderKataGrid('my-kata-grid',kataVids,profile.step||0,false,i);\}<br><br>function showMySec(id)\{<br>  ['kata','logbook'].forEach(s=>\{<br>    document.getElementById('my-sec-'+s).style
a-grid',DEMO.vids,DEMO.step,true,i);\}<br>function showDemoSec(id)\{<br>  ['kata','logbook','cert'].forEach(s=>\{<br>    document.getElementById('demo-sec-'+s).classList.toggle('active',s===id);<br>    document.getElementById('demo-sec-'+s).style.display=s===id?'block':'none';<br>    document.getElementById('demo-tog-'+s).classList.toggle('active',s===id);<br>  \});<br>\}<br><br>/* \u9552 \u9552 \u9552  AUTH \u9552 \u9552 \u9552  */<br><br>function toggleAuthMode()\{<br>  isReg=!isReg;<br>  ['login-name','login-surname','login-code'].forEach(id=>document.getElementById(id).classList.toggle('hidden',!isReg));<br>  document.getElementById('login-submit').textContent=isReg?'Registrati':'Accedi';<br>  document.getElementById('login-toggle-text').textContent=isReg?'Hai gi\'e0 un account?':'Non hai un account?';<br>  document.getElementById('login-toggle-link').textContent=isReg?'Accedi':'Registrati';<br>  document.getElementById('login-error').style.display='none';<br>\}<br><br>async function handleAuth()\{<br>  const email=document.getElementById('login-email').value.trim();<br>  const pw=document.getElementById('login-password').value;<br>  if(!email||!pw)return showErr('Inserisci email e password');<br>  const btn=document.getElementById('login-submit');btn.disabled=true;btn.innerHTML='<span class="loader"></span>';<br>  try\{<br>    if(!sb)throw new Error('demo');<br>    if(isReg)\{<br>      const nome=document.getElementById('login-name').value.trim(),cogn=document.getElementById('login-surname').value.trim();<br>      if(!nome||!cogn)\{showErr('Inserisci nome e cognome');return\}<br>      const\{data,error\}=await sb.auth.signUp(\{email,password:pw,options:\{data:\{nome,cognome:cogn\}\}\});if(error)throw error;<br>      // Se confirm email \'e8 attivo, l'utente deve confermare prima di entrare<br>      if(data.user&&!data.user.email_confirmed_at&&!data.session)\{<br>        try\{sessionStorage.setItem('kc_reg',JSON.stringify(\{nome,cognome:cogn\}))\}catch(e)\{\}<br>        showConfirmMsg(email);return;<br>      \}<br>      user=data.user;<br>      const\{error:insErr\}=await sb.from('profiles').insert(\{user_id:user.id,email,nome,cognome:cogn,step:0\});<br>      if(insErr)console.warn('Profile insert:',insErr.message);<br>      profile=\{user_id:user.id,email,nome,cognome:cogn,step:0,struttura:'',bio:'',citta:'',foto_url:'',codice_allievo:''\};<br>      const code=document.getElementById('login-code').value.trim();<br>      if(code)await sb.from('event_participants').insert(\{user_id:user.id,event_code:code\});<br>    \}else\{<br>      const\{data,error\}=await sb.auth.signInWithPassword(\{email,password:pw\});if(error)throw error;user=data.user;<br>    \}<br>    await loadAll();showScreen('screen-app');renderApp();<br>  \}catch(e)\{<br>    if(e.message==='demo')\{profile=\{...DEMO,photo_url:null\};kataVids=DEMO.vids;logbook=DEMO.log;communityMembers=DEMO_COMMUNITY;showScreen('screen-app');renderApp();\}<br>    else showErr(authErrIT(e.message)||'Errore');<br>  \}finally\{btn.disabled=false;btn.textContent=isReg?'Registrati':'Accedi'\}<br>\}<br><br>function showConfirmMsg(email)\{<br>  document.getElementById('login-error').style.display='none';<br>  const box=document.querySelector('.login-box');<br>  box.innerHTML=`<br>    <div class="logo" style="font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--text3);margin-bottom:32px"><br>      KataClimb<span style="color:var(--open)">\'ae</span><br>    </div><br>    <div style="font-size:32px;margin-bottom:16px">
